<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon (API 26+). The brand logo is a full-bleed square image
  placed on the background layer so the launcher only applies its shape mask
  (circle / squircle / rounded square) without shrinking the artwork into the
  smaller foreground safe-zone.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_image" />
    <foreground android:drawable="@android:color/transparent" />
</adaptive-icon>
