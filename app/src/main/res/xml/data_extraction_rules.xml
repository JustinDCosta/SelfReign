<?xml version="1.0" encoding="utf-8"?>
<!--
  Disable cloud backup and device-to-device transfer of app data.
  Habit and note data is private and stays only on the device, supporting
  data-minimisation principles (e.g. GDPR).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
